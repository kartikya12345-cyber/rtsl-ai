{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks"
  },
  "deploy": {
    "startCommand": ". /opt/venv/bin/activate && uvicorn main:app --host 0.0.0.0 --port $PORT",
    "healthcheckPath": "/",
    "restartPolicyType": "onFailure",
    "restartPolicyMaxRetries": 3
  }
}
